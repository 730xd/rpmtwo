<Window x:Class="rpmtwo.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:rpmtwo"
        mc:Ignorable="d"
       
        Title="LoginWindow" Height="450" Width="800">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <TextBlock Grid.Row="0" Text="Аэрофлот - Система управления рейсами" 
                   FontSize="16" FontWeight="Bold" TextAlignment="Center" 
                   Margin="0,0,0,20" Foreground="#1A237E"/>

        <!-- Логин -->
        <TextBlock Grid.Row="1" Text="Логин:" FontWeight="Bold" Margin="0,0,0,5"/>
        <TextBox x:Name="txtLogin" Grid.Row="2" Margin="0,0,0,15" Height="30" FontSize="14"/>

        <!-- Пароль -->
        <TextBlock Grid.Row="3" Text="Пароль:" FontWeight="Bold" Margin="0,0,0,5"/>
        <PasswordBox x:Name="txtPassword" Grid.Row="4" Margin="0,0,0,15" Height="30" FontSize="14"/>

        <!-- Капча -->
        <Border Grid.Row="5" Background="#F0F0F0" Padding="10" CornerRadius="5" Margin="0,0,0,15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="Введите код с картинки:" FontWeight="Bold" Margin="0,0,0,10"/>
                    <TextBox x:Name="txtCaptcha" Height="30" FontSize="14"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Margin="10,0,0,0" VerticalAlignment="Center">
                    <TextBlock x:Name="lblCaptcha" FontSize="24" FontWeight="Bold" 
                               FontFamily="Curlz MT" TextAlignment="Center" 
                               Background="LightGray" Padding="15,10" Margin="0,0,0,5"/>
                    <Button Content="⟳" Width="30" Height="30" Click="RefreshCaptcha_Click" 
                            FontSize="16" ToolTip="Обновить капчу"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Кнопки -->
        <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,0">
            <Button x:Name="btnLogin" Content="Войти" Width="100" Height="35" Margin="5" 
                    Click="Login_Click" Background="#4CAF50" Foreground="White" FontWeight="Bold"/>
            <Button x:Name="btnExit" Content="Выход" Width="100" Height="35" Margin="5" 
                    Click="Exit_Click" Background="#F44336" Foreground="White" FontWeight="Bold"/>
        </StackPanel>

        
    </Grid>
</Window>
