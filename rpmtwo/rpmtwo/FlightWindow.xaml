<Window x:Class="rpmtwo.FlightWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:rpmtwo"
        mc:Ignorable="d"
        Title="FlightWindow" Height="450" Width="800">
    <DockPanel Margin="15">
        <!-- Кнопки внизу -->
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,0">
            <Button x:Name="btnOk" Content="OK" Width="100" Height="35" Margin="10,0" Click="Ok_Click" Background="#4CAF50" Foreground="White"/>
            <Button x:Name="btnCancel" Content="Отмена" Width="100" Height="35" Margin="10,0" Click="Cancel_Click" Background="#F44336" Foreground="White"/>
        </StackPanel>

        <!-- Поля ввода с прокруткой -->
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <TextBlock Text="Номер рейса:" FontWeight="Bold" Margin="0,0,0,5"/>
                <TextBox x:Name="txtFlightNumber" Margin="0,0,0,15"/>

                <TextBlock Text="Пункт назначения:" FontWeight="Bold" Margin="0,0,0,5"/>
                <TextBox x:Name="txtDestination" Margin="0,0,0,15"/>

                <TextBlock Text="Время вылета:" FontWeight="Bold" Margin="0,0,0,5"/>
                <DatePicker x:Name="dpDepartureDate" Margin="0,0,0,5"/>
                <TextBox x:Name="txtDepartureTime" Text="12:00" Margin="0,0,0,15"/>

                <TextBlock Text="Время прибытия:" FontWeight="Bold" Margin="0,0,0,5"/>
                <DatePicker x:Name="dpArrivalDate" Margin="0,0,0,5"/>
                <TextBox x:Name="txtArrivalTime" Text="14:00" Margin="0,0,0,15"/>

                <TextBlock Text="Свободных мест:" FontWeight="Bold" Margin="0,0,0,5"/>
                <TextBox x:Name="txtAvailableSeats" Margin="0,0,0,15"/>

                <TextBlock Text="Тип самолета:" FontWeight="Bold" Margin="0,0,0,5"/>
                <TextBox x:Name="txtAircraftType" Margin="0,0,0,15"/>

                <TextBlock Text="Вместимость:" FontWeight="Bold" Margin="0,0,0,5"/>
                <TextBox x:Name="txtCapacity" Margin="0,0,0,15"/>
            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</Window>
